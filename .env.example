# ---- HubSpot (reuniões / meetings dos closers) ----
# Private App em Settings > Integrations > Private Apps.
# Scopes de leitura necessários:
#   crm.objects.meetings.read  -> as reuniões (hs_meeting_start_time/end/outcome)
#   crm.objects.owners.read    -> nome do closer (owner da reunião)
#   crm.objects.contacts.read  -> nome/empresa do contato associado (opcional)
HUBSPOT_TOKEN=pat-na1-xxxxxxxx

# (opcional) mapeamento dos times de closers -> owners do HubSpot.
# Se não definir, usa os defaults do código (api/reunioes-hoje.js).
